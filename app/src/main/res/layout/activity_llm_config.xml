<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <io.agents.pokeclaw.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16pt"
        android:paddingTop="8pt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Active Model Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Active Model"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16pt">

                    <TextView
                        android:layout_width="40pt"
                        android:layout_height="40pt"
                        android:background="@drawable/bg_avatar_ai"
                        android:gravity="center"
                        android:text="🦞"
                        android:textSize="22pt" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12pt"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvActiveModelName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No model"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15pt"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvActiveModelMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2pt"
                            android:text="Tap to download a model"
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="12pt" />

                        <TextView
                            android:id="@+id/tvActiveModelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4pt"
                            android:text="● Not configured"
                            android:textColor="@color/colorSuccessPrimary"
                            android:textSize="12pt" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Available Models -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Available Models"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutModelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Storage section hidden — not useful for end users -->
            <TextView
                android:id="@+id/tvStorageInfo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <ProgressBar
                android:id="@+id/progressStorage"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvStorageDetail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Cloud LLM — OpenAI-compatible API -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="Cloud LLM (Advanced)"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCloudTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="12pt"
                android:text="@string/llm_config_tip"
                android:textColor="@color/colorTextTertiary"
                android:textSize="12pt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_api_key"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_api_key_hint"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_base_url"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_base_url_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_model_name"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etModelName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_model_name_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_section_sampling"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_temperature"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etTemperature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_temperature_hint"
                    android:importantForAutofill="no"
                    android:inputType="numberDecimal|numberSigned"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_top_p"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etTopP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_top_p_hint"
                    android:importantForAutofill="no"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_max_output_tokens"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etMaxOutputTokens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_max_output_tokens_hint"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_section_skills"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_skills"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etSkillsMarkdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120pt"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="@string/llm_config_skills_hint"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine|textCapSentences"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="14pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_section_mcp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13pt"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMcpTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_mcp_tip"
                android:textColor="@color/colorTextTertiary"
                android:textSize="12pt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_mcp_catalog_url"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etMcpCatalogUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_mcp_catalog_url_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="@string/llm_config_mcp_invoke_url"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etMcpInvokeUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48pt"
                    android:background="@null"
                    android:hint="@string/llm_config_mcp_invoke_url_hint"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <io.agents.pokeclaw.widget.KButton
                android:id="@+id/btnSaveCloud"
                android:layout_width="match_parent"
                android:layout_height="48pt"
                android:layout_marginTop="20pt"
                android:layout_marginBottom="24pt"
                android:gravity="center"
                android:text="@string/common_save"
                android:textColor="@color/colorBrandOnPrimary"
                android:textSize="15pt"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
